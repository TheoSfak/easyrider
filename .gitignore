# EasyRide - Gitignore

# Local configuration (contains database credentials)
config.local.php
.private/

# IDE/Editor
.vscode/
.idea/
*.sublime-*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Dependencies (if any added later)
vendor/
node_modules/

# Cache
*.cache
cache/

# Uploads (if added later)
uploads/

# Backup files
backups/
*.bak
*.backup
*.sql.gz

# Temporary files
*.tmp
*.temp
~*

# Superpowers session scratch (SDD ledgers, brainstorm mockups)
.superpowers/
